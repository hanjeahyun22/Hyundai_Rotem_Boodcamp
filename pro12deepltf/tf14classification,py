print("2) Functional API 버전 (실무에서 주로 사용)")
# 다중 입출력 가능
# 구조 유연 -> 복잡한 모델에 효과적

from tensorflow.keras.models import Model
inputs = Input(shape=(2,))
outputs = Dense(units=4, activation='relu')(inputs)
outputs = Dense(units=1, activation='sigmoid')(outputs)
model_func = Model(inputs=inputs, outputs=outputs)
print(model_func.summary())

model_func.compile(loss='binary_crossentropy', optimizer=Adam(learning_rate=0.01), metrics=['accuracy'])
m_eval2 = model_func.fit(x_data, y_data, epochs=20, batch_size=1, verbose=0)

print(m_eval2)
print(f"평가 결과 2 : 손실={m_eval2.history['loss'][-1]:.4f}, 정확도={m_eval2.history['accuracy'][-1]:.4f}")


print("\n2-1) Functional API 버전2 (다중 입력)")
# 이전 버전 : [x1, x2] -> Dense -> Dense -> 출력
# 다중 입력 : 입력을 따로 받아서 각각 특징을 뽑아 합치는 방식   ->  각각 따로 전처리 가능
# x1 -> Dense
#               -> concat   -> Dense    -> 출력
# x2 -> Dense

from tensorflow.keras.layers import Concatenate

# 입력 분리
input1 = Input(shape=(1,))
input2 = Input(shape=(1,))

# 각각 처리
x1 = Dense(units=2, activation='relu')(input1)
x2 = Dense(units=4, activation='relu')(input2)

# 합치기
merged = Concatenate()([x1, x2])


output = Dense(units=1, activation='sigmoid')(merged)

multi_model = Model(inputs=[input1, input2], outputs=output)
print(multi_model.summary())

multi_model.compile(loss="binary_crossentropy", optimizer=Adam(learning_rate=0.01), metrics=['accuracy'])

# 데이터를 분리해서 입력
x1_data = x_data[:, 0].reshape(-1, 1)
x2_data = x_data[:, 1].reshape(-1, 1)

multi_model.fit([x1_data, x2_data], y_data, epochs=20, batch_size=1, verbose=0)
m_eval2_multi = multi_model.evaluate([x1_data, x2_data], y_data, verbose=0)
print(m_eval2_multi)
print(f"평가 결과 3 : 손실={m_eval2_multi[0]:.4f}, 정확도={m_eval2_multi[1]:.4f}")


print("\n3) Model Subclassing 방식(완전 자유로운 형태 - 프로그래머 능력 중요)")
class MyModel(Model):
    def __init__(self):
        super(MyModel, self).__init__()
        
        # 레이어 정의
        self.dense1 = Dense(units=4, activation='relu')
        self.dense2 = Dense(units=1, activation='sigmoid')

    # forward 연산 정의
    def call(self, inputs):
        x = self.dense1(inputs)
        return self.dense2(x)

sub_model = MyModel()

sub_model.build(input_shape=(None, 2))
print(sub_model.summary())
sub_model.compile(loss="binary_crossentropy", optimizer=Adam(learning_rate=0.01), metrics=['accuracy'])
m_eval_sub = sub_model.fit(x_data, y_data, epochs=20, batch_size=1, verbose=0)
print(m_eval_sub)
print(f"평가 결과 4 : 손실={m_eval_sub.history['loss'][-1]:.4f}, 정확도={m_eval_sub.history['accuracy'][-1]:.4f}")